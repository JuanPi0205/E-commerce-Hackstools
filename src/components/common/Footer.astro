---
// src/components/common/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="mt-0 bg-black py-20 text-white">
  <div class="container mx-auto max-w-7xl px-4">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-3 md:gap-8">
      <!-- Logo and Description -->
      <div class="col-span-1">
        <a
          href="/"
          class="mb-6 inline-block text-2xl font-bold tracking-tight text-white"
          >HackTools</a
        >
        <p class="mb-8 max-w-sm text-sm leading-relaxed text-[#888]">
          We are a premier provider of tactical cyber security gear located in
          Medellin, Colombia. Our boutique offers more than standard
          equipment—we provide arsenals.
        </p>

        <!-- Social Icons -->
        <div class="mt-16 flex items-center gap-6">
          <a href="#" class="text-white transition-colors hover:text-gray-400">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              stroke="none"
              ><path
                d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
              ></path></svg
            >
          </a>
          <a href="#" class="text-white transition-colors hover:text-gray-400">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
              ></path></svg
            >
          </a>
          <a href="#" class="text-white transition-colors hover:text-gray-400">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg
            >
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="col-span-1 md:ml-12">
        <h4 class="mb-6 font-semibold text-white">Services</h4>
        <ul class="space-y-4 text-sm font-light text-[#888]">
          <li>
            <a href="#" class="transition-colors hover:text-white"
              >Bonus program</a>
          </li>
          <li>
            <a href="#" class="transition-colors hover:text-white"
              >Gift cards</a>
          </li>
          <li>
            <a href="#" class="transition-colors hover:text-white"
              >Credit and payment</a>
          </li>
          <li>
            <a href="#" class="transition-colors hover:text-white"
              >Service contracts</a>
          </li>
          <li>
            <a href="#" class="transition-colors hover:text-white"
              >Non-cash account</a>
          </li>
          <li>
            <a href="#" class="transition-colors hover:text-white">Payment</a>
          </li>
        </ul>
      </div>

      <!-- Assistance -->
      <div class="col-span-1">
        <h4 class="mb-6 font-semibold text-white">Assistance to the buyer</h4>
        <ul class="space-y-4 text-sm font-light text-[#888]">
          <li>
            <a href="#" class="transition-colors hover:text-white"
              >Find an order</a>
          </li>
          <li>
            <a href="#" class="transition-colors hover:text-white"
              >Terms of delivery</a>
          </li>
          <li>
            <a href="#" class="transition-colors hover:text-white"
              >Exchange and return of goods</a>
          </li>
          <li>
            <a href="#" class="transition-colors hover:text-white">Guarantee</a>
          </li>
          <li>
            <a href="#" class="transition-colors hover:text-white"
              >Frequently asked questions</a>
          </li>
          <li>
            <a href="#" class="transition-colors hover:text-white"
              >Terms of use of the site</a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</footer>
