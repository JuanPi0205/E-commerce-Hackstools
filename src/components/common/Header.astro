---
// src/components/common/Header.astro
import LoginModal from "./LoginModal.astro";

// Fuente de verdad de la sesión: las cookies httpOnly reales (leídas en el servidor).
// El access token expira en ~1-2h pero el refresh token dura 30 días, así que si hay
// cualquiera de los dos consideramos al usuario autenticado (profile.astro refresca solo).
const isAuthenticated = Boolean(
  Astro.cookies.get("customer_access_token")?.value ||
    Astro.cookies.get("customer_refresh_token")?.value
);
---

<header class="border-b border-gray-100 bg-white py-4">
  <div
    class="container mx-auto flex max-w-7xl items-center justify-between px-4"
  >
    <!-- Logo & Search -->
    <div class="flex flex-1 items-center gap-8">
      <a
        href="/"
        class="text-2xl font-bold tracking-tight text-black no-underline"
        >HackTools</a
      >

      <div
        class="hidden max-w-sm flex-1 items-center rounded-lg bg-[#F5F5F5] px-4 py-2 md:flex"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#9CA3AF"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mr-2"
          ><circle cx="11" cy="11" r="8"></circle><line
            x1="21"
            y1="21"
            x2="16.65"
            y2="16.65"></line></svg
        >
        <input
          type="text"
          placeholder="Search"
          class="w-full border-none bg-transparent text-sm text-gray-700 placeholder-gray-400 outline-none"
        />
      </div>
    </div>

    <!-- Navigation List -->
    <nav class="hidden lg:block">
      <ul class="m-0 flex list-none items-center gap-8 p-0 text-sm font-medium">
        <li><a href="/" class="text-black">Home</a></li>
        <li>
          <a
            href="/catalog"
            class="text-gray-400 transition-colors hover:text-black">Catalog</a
          >
        </li>
      </ul>
    </nav>

    <!-- Icons -->
    <div class="ml-8 flex items-center gap-6">
      <a
        id="logout-link"
        href="/auth/logout"
        aria-label="Cerrar sesión"
        class="relative text-black transition-opacity hover:opacity-70"
        style={isAuthenticated ? "" : "display: none;"}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
      </a>
      <a
        id="login-link"
        href="/auth/login"
        data-login-trigger
        aria-label="Iniciar sesión"
        class="relative text-black transition-opacity hover:opacity-70"
        style={isAuthenticated ? "display: none;" : ""}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
      <a
        id="profile-link"
        href="/profile"
        aria-label="Mi Perfil"
        class="relative text-black transition-opacity hover:opacity-70"
        style={isAuthenticated ? "" : "display: none;"}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
      <a
        href="/profile"
        aria-label="Wishlist"
        class="relative text-black transition-opacity hover:opacity-70"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
          ></path></svg
        >
        <span
          id="wishlist-badge"
          style="display:none"
          class="absolute -top-2 -right-2 flex h-[18px] min-w-[18px] items-center justify-center rounded-full bg-red-500 px-[4px] text-[10px] leading-none font-bold text-white"
        ></span>
      </a>
      <a
        href="/cart"
        aria-label="Cart"
        class="relative text-black transition-opacity hover:opacity-70"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"
          ></circle><path
            d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"
          ></path></svg
        >
        <span
          id="cart-badge"
          style="display:none"
          class="absolute -top-2 -right-2 flex h-[18px] min-w-[18px] items-center justify-center rounded-full bg-black px-[4px] text-[10px] leading-none font-bold text-white"
        ></span>
      </a>
    </div>
  </div>
</header>

<LoginModal />

<script>
  import { cart, clearCart } from "../../stores/cart";
  import { getWishlistCount, clearWishlist } from "../../utils/wishlist";

  function updateWishlistBadge() {
    const badge = document.getElementById("wishlist-badge");
    if (!badge) return;
    const count = getWishlistCount();
    badge.textContent = count > 99 ? "99+" : String(count);
    badge.style.display = count > 0 ? "flex" : "none";
  }

  updateWishlistBadge();
  window.addEventListener("wishlist:updated", updateWishlistBadge);

  // Subscribe to real Shopify cart for badge
  cart.subscribe((cartData) => {
    const badge = document.getElementById("cart-badge");
    if (!badge) return;
    const count = cartData?.totalQuantity || 0;
    badge.textContent = count > 99 ? "99+" : String(count);
    badge.style.display = count > 0 ? "flex" : "none";
  });

  // La visibilidad de login/logout/perfil se decide en el servidor (SSR) según las
  // cookies httpOnly reales — ver el frontmatter de este componente. Aquí no se toca.

  // Al cerrar sesión, vaciar el carrito y los favoritos locales antes de navegar.
  // Cubre tanto el ícono del Header como el botón "Cerrar Sesión" de /profile.
  // Los favoritos del usuario siguen guardados en Shopify (metafield).
  document.querySelectorAll('a[href="/auth/logout"]').forEach((el) => {
    el.addEventListener("click", () => {
      clearCart();
      clearWishlist();
    });
  });

  // ===== Modal de login =====
  const loginModal = document.getElementById("login-modal");
  const loginModalCard = document.getElementById("login-modal-card");
  const loginModalClose = document.getElementById("login-modal-close");
  const loginModalForm = document.getElementById("login-modal-form") as HTMLFormElement | null;
  const loginModalEmail = document.getElementById("login-modal-email") as HTMLInputElement | null;
  const loginModalShop = document.getElementById("login-modal-shop");
  const loginModalGoogle = document.getElementById("login-modal-google");

  function openLoginModal() {
    if (!loginModal) return;
    loginModal.classList.remove("hidden");
    loginModal.classList.add("flex");
    loginModal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    setTimeout(() => loginModalEmail?.focus(), 50);
  }

  function closeLoginModal() {
    if (!loginModal) return;
    loginModal.classList.add("hidden");
    loginModal.classList.remove("flex");
    loginModal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  // Abrir desde cualquier disparador con [data-login-trigger].
  document.querySelectorAll("[data-login-trigger]").forEach((el) => {
    el.addEventListener("click", (e) => {
      e.preventDefault();
      openLoginModal();
    });
  });

  loginModalClose?.addEventListener("click", closeLoginModal);

  // Cerrar al hacer clic fuera de la tarjeta.
  loginModal?.addEventListener("click", (e) => {
    if (loginModalCard && !loginModalCard.contains(e.target as Node)) closeLoginModal();
  });

  // Cerrar con Escape.
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && loginModal && !loginModal.classList.contains("hidden")) {
      closeLoginModal();
    }
  });

  // Enviar correo → página hosted de Shopify con el correo pre-llenado (login_hint).
  loginModalForm?.addEventListener("submit", (e) => {
    e.preventDefault();
    const email = loginModalEmail?.value.trim();
    if (!email) return;
    window.location.href = `/auth/login?login_hint=${encodeURIComponent(email)}`;
  });

  // Shop y Google → misma página segura de Shopify (ahí el usuario elige el proveedor).
  loginModalShop?.addEventListener("click", () => {
    window.location.href = "/auth/login";
  });
  loginModalGoogle?.addEventListener("click", () => {
    window.location.href = "/auth/login";
  });
</script>
