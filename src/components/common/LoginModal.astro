---
// src/components/common/LoginModal.astro
// Modal "launcher" de inicio de sesión para la Customer Account API (passwordless).
// El usuario ingresa su correo y lo enviamos a la página segura de Shopify, que le
// manda un código de un solo uso. Si es su primera vez, Shopify crea la cuenta sola.
// Los botones de Shop y Google redirigen a esa misma página hosted de Shopify.
---

<div
  id="login-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4 backdrop-blur-sm"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="login-modal-title"
>
  <div
    id="login-modal-card"
    class="relative w-full max-w-sm rounded-2xl bg-white p-8 shadow-2xl"
  >
    <!-- Cerrar -->
    <button
      id="login-modal-close"
      type="button"
      aria-label="Cerrar"
      class="absolute right-4 top-4 text-gray-400 transition-colors hover:text-black"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>

    <h2 id="login-modal-title" class="mb-1 text-center text-2xl font-bold tracking-tight text-gray-900">
      Iniciar sesión
    </h2>
    <p class="mb-6 text-center text-sm text-gray-500">
      Ingresa tu correo y te enviaremos un código para entrar.
    </p>

    <!-- Formulario de correo -->
    <form id="login-modal-form" class="space-y-4">
      <div>
        <label for="login-modal-email" class="mb-1 block text-sm font-medium text-gray-700">
          Correo electrónico
        </label>
        <input
          id="login-modal-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="tu@correo.com"
          class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 outline-none transition-colors focus:border-black focus:ring-1 focus:ring-black"
        />
      </div>

      <button
        type="submit"
        class="w-full rounded-lg bg-black px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gray-800"
      >
        Continuar con correo
      </button>
    </form>

    <!-- Separador -->
    <div class="my-6 flex items-center gap-3">
      <span class="h-px flex-1 bg-gray-200"></span>
      <span class="text-xs font-medium uppercase tracking-wide text-gray-400">o continúa con</span>
      <span class="h-px flex-1 bg-gray-200"></span>
    </div>

    <!-- Botones de proveedores -->
    <div class="space-y-3">
      <!-- Shop -->
      <button
        id="login-modal-shop"
        type="button"
        class="flex w-full items-center justify-center gap-3 rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-medium text-gray-900 transition-colors hover:bg-gray-50"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="24" height="24" rx="6" fill="#5A31F4"></rect>
          <path d="M12 6.2c-2.4 0-3.7 1.2-3.9 2.6-.2 1.3.6 2.2 2.3 2.7l1.1.3c.7.2.9.4.9.8 0 .4-.4.7-1.1.7-.9 0-1.4-.4-1.5-1l-1.9.4c.2 1.5 1.5 2.4 3.4 2.4 2.2 0 3.6-1.1 3.6-2.8 0-1.3-.8-2-2.4-2.5l-1.1-.3c-.6-.2-.9-.4-.8-.8.1-.4.5-.6 1.1-.6.8 0 1.2.4 1.3.9l1.9-.4C14.5 7 13.4 6.2 12 6.2Z" fill="white"></path>
        </svg>
        Continuar con Shop
      </button>

      <!-- Google -->
      <button
        id="login-modal-google"
        type="button"
        class="flex w-full items-center justify-center gap-3 rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-medium text-gray-900 transition-colors hover:bg-gray-50"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.27-4.74 3.27-8.1Z"></path>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"></path>
          <path fill="#FBBC05" d="M5.84 14.1a6.6 6.6 0 0 1 0-4.2V7.06H2.18a11 11 0 0 0 0 9.88l3.66-2.84Z"></path>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A11 11 0 0 0 2.18 7.06l3.66 2.84C6.71 7.3 9.14 5.38 12 5.38Z"></path>
        </svg>
        Continuar con Google
      </button>
    </div>

    <p class="mt-6 text-center text-xs text-gray-400">
      ¿Primera vez? Tu cuenta se crea automáticamente al ingresar con tu correo.
    </p>
  </div>
</div>
<!-- La lógica de apertura/cierre vive en el <script> de Header.astro
     (que se bundlea de forma fiable). Este componente solo aporta el markup. -->
