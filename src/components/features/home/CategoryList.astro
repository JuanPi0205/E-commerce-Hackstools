---
// src/components/features/home/CategoryList.astro
import { getCollections } from "../../../utils/shopify";

// Colecciones que NO deben mostrarse como categoría en el home:
// - "bento-grid": exclusiva para los 4 cards del PromoGrid.
// - "frontpage" / "Página de inicio": la colección por defecto de Shopify.
const EXCLUDED_HANDLES = ["bento-grid", "frontpage"];
const EXCLUDED_TITLES = ["página de inicio", "pagina de inicio", "home page", "frontpage"];

// Solicitamos las colecciones a Shopify y filtramos las excluidas.
const collections = (await getCollections(20)).filter((c: any) => {
  const handle = (c.handle || "").toLowerCase();
  const title = (c.title || "").toLowerCase();
  return !EXCLUDED_HANDLES.includes(handle) && !EXCLUDED_TITLES.includes(title);
});

// Mapeamos los SVGs exactos que tenías, vinculándolos al 'handle' de Shopify.
const iconMap: Record<string, string> = {
  software: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>`,
  hardware: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>`,
  hotplugs: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="7" r="2"></circle><path d="M14 7h6"></path><path d="M10 9v6"></path><path d="M22 12h-6"></path><path d="M10 17v4"></path><path d="M8 7h2"></path><circle cx="6" cy="7" r="2"></circle><circle cx="14" cy="12" r="2"></circle><path d="M14 14v6"></path><path d="M10 14h2"></path><circle cx="10" cy="19" r="2"></circle><circle cx="14" cy="22" r="2"></circle></svg>`,
  implants: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="14" x="8" y="6" rx="4"/><path d="m19 7-3 2"/><path d="m5 7 3 2"/><path d="m19 19-3-2"/><path d="m5 19 3-2"/><path d="M20 13h-4"/><path d="M4 13h4"/><path d="m10 4 1 2"/><path d="m14 4-1 2"/></svg>`,
  "remote-access": `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="16" y="16" width="6" height="6" rx="1"></rect><rect x="2" y="16" width="6" height="6" rx="1"></rect><rect x="9" y="2" width="6" height="6" rx="1"></rect><path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1v3"></path><path d="M12 12V8"></path></svg>`,
  workbench: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>`,
};
---

<section class="bg-[#FAFAFA] py-16">
  <div class="container mx-auto max-w-7xl px-4">
    <div class="mb-10 flex items-center justify-between">
      <h2 class="text-2xl font-bold text-black">Browse By Category</h2>
      <div class="flex gap-4">
        <button
          id="cat-prev"
          class="flex h-8 w-8 items-center justify-center rounded-full border border-gray-300 text-black transition-colors hover:bg-gray-100"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polyline points="15 18 9 12 15 6"></polyline></svg
          >
        </button>
        <button
          id="cat-next"
          class="flex h-8 w-8 items-center justify-center rounded-full border border-gray-300 text-black transition-colors hover:bg-gray-100"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polyline points="9 18 15 12 9 6"></polyline></svg
          >
        </button>
      </div>
    </div>

    <div id="cat-container" class="flex w-full gap-6 overflow-x-auto snap-x scroll-smooth pb-4 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
      {
        collections.map((collection) => {
          // Buscamos el ícono basado en el handle de Shopify
          const iconSvg = iconMap[collection.handle];
          // Imagen de respaldo por si creas una categoría nueva en Shopify que no tenga ícono mapeado
          const fallbackImage =
            collection.image?.url || "https://placehold.co/100x100";

          return (
            <a
              href={`/category/${collection.handle}`}
              class="group flex flex-1 snap-start flex-col items-center justify-center rounded-xl bg-[#EDEDED] py-8 transition-all duration-300 hover:bg-black hover:text-white min-w-[140px] sm:min-w-[160px] lg:min-w-[calc((100%-7.5rem)/6)]"
            >
              <div class="mb-4 flex h-8 w-8 items-center justify-center text-black group-hover:text-white">
                {iconSvg ? (
                  <Fragment set:html={iconSvg} />
                ) : (
                  <img
                    src={fallbackImage}
                    alt={collection.title}
                    class="h-8 w-8 object-contain mix-blend-multiply transition-all group-hover:invert"
                  />
                )}
              </div>
              <span class="text-sm font-medium text-black group-hover:text-white">
                {collection.title}
              </span>
            </a>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  const container = document.getElementById("cat-container");
  const prevBtn = document.getElementById("cat-prev");
  const nextBtn = document.getElementById("cat-next");

  if (container && prevBtn && nextBtn) {
    prevBtn.addEventListener("click", () => {
      container.scrollBy({ left: -300, behavior: "smooth" });
    });
    nextBtn.addEventListener("click", () => {
      container.scrollBy({ left: 300, behavior: "smooth" });
    });
  }
</script>
