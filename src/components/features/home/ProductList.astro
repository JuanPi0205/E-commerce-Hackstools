---
// src/components/features/home/ProductList.astro
import type { z } from "zod";
import type { ProductResult } from "../../../utils/schemas";

export interface Props {
  products: z.infer<typeof ProductResult>[];
}

const { products } = Astro.props;

const HEART_EMPTY = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#CFCFCF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>`;
const HEART_FILLED = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#EF4444" stroke="#EF4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>`;
---

<section class="py-16 bg-white">
  <div class="container mx-auto px-4 max-w-7xl">
    
    <!-- Tabs -->
    <div class="flex gap-8 mb-10 border-b border-gray-200">
      <button data-tab="new-arrivals" class="tab-btn text-black font-semibold pb-2 border-b-2 border-black active">New Arrival</button>
      <button data-tab="bestsellers" class="tab-btn text-[#888] font-medium pb-2 border-b-2 border-transparent hover:text-black transition-colors">Bestseller</button>
      <button data-tab="featured" class="tab-btn text-[#888] font-medium pb-2 border-b-2 border-transparent hover:text-black transition-colors">Featured Products</button>
    </div>

    <!-- Product Grid -->
    <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 transition-opacity duration-300">
      {products.map((product) => {
        const variantId = product?.variants?.nodes?.[0]?.id || "";
        const price = product?.variants?.nodes?.[0]?.price?.amount || "0.00";
        const image = product?.images?.nodes?.[0]?.url || product?.featuredImage?.url || "https://placehold.co/400x400";
        
        return (
        <div class="bg-[#F6F6F6] rounded-xl p-6 flex flex-col items-center text-center relative group">

          <!-- Wishlist Button -->
          <button
            class="btn-wishlist absolute top-4 right-4 transition-transform hover:scale-110"
            data-id={product?.id}
            data-title={product?.title}
            data-price={price}
            data-image={image}
            data-handle={product?.handle}
            aria-label="Add to wishlist"
          >
            <Fragment set:html={HEART_EMPTY} />
          </button>
          
          <!-- Product Image -->
          <div class="w-full h-[200px] flex items-center justify-center mb-6 mt-4">
            <img src={image} alt={product?.title} class="max-h-full max-w-[80%] object-contain mix-blend-multiply transition-transform duration-300 group-hover:scale-105" />
          </div>

          <!-- Product Details -->
          <h3 class="text-sm font-medium text-black mb-2 line-clamp-2 px-2 h-[40px] leading-snug">{product?.title}</h3>
          <p class="text-2xl font-bold text-black mb-6">${price}</p>
          
          <!-- Buy Now Button -->
          <button
            class="btn-add-to-cart w-full bg-black text-white font-medium py-3 rounded-lg hover:bg-gray-800 transition-colors mt-auto"
            data-variant-id={variantId}
          >
            Buy Now
          </button>
        </div>
      )})}
    </div>

  </div>
</section>

<script>
  import { addCartItem } from '../../../stores/cart';
  import { toggleWishlist, isInWishlist } from '../../../utils/wishlist';

  const HEART_EMPTY = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#CFCFCF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>`;
  const HEART_FILLED = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#EF4444" stroke="#EF4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>`;

  function syncHearts() {
    document.querySelectorAll<HTMLButtonElement>('.btn-wishlist').forEach((btn) => {
      const id = btn.dataset.id!;
      btn.innerHTML = isInWishlist(id) ? HEART_FILLED : HEART_EMPTY;
    });
  }

  function bindEvents() {
    // Wire wishlist buttons
    document.querySelectorAll<HTMLButtonElement>('.btn-wishlist').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id!;
        toggleWishlist({
          id,
          title: btn.dataset.title!,
          price: parseFloat(btn.dataset.price!),
          image: btn.dataset.image!,
          handle: btn.dataset.handle!,
        });
        syncHearts();
      });
    });

    // Wire add-to-cart buttons
    document.querySelectorAll<HTMLButtonElement>('.btn-add-to-cart').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const variantId = btn.dataset.variantId!;
        if (!variantId) return;

        const orig = btn.textContent;
        btn.textContent = 'Adding...';
        btn.disabled = true;
        
        await addCartItem({ variantId, quantity: 1 });
        
        btn.textContent = '✓ Added!';
        btn.classList.replace('bg-black', 'bg-green-600');
        btn.classList.remove('hover:bg-gray-800');
        setTimeout(() => {
          btn.textContent = orig;
          btn.disabled = false;
          btn.classList.replace('bg-green-600', 'bg-black');
          btn.classList.add('hover:bg-gray-800');
        }, 1200);
      });
    });
  }

  // Tabs logic
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const grid = document.getElementById('products-grid');

  buttons.forEach(btn => {
    btn.addEventListener('click', async () => {
      // Update UI
      buttons.forEach(b => {
        b.classList.remove('text-black', 'border-black', 'active');
        b.classList.add('text-[#888]', 'border-transparent');
      });
      btn.classList.remove('text-[#888]', 'border-transparent');
      btn.classList.add('text-black', 'border-black', 'active');

      const handle = btn.dataset.tab;
      if (!handle || !grid) return;
      
      grid.classList.add('opacity-50');

      try {
        const res = await fetch(`/api/collection/${handle}`);
        const products = await res.json();

        if (products && products.length > 0) {
          grid.innerHTML = products.map((product: any) => {
            const variantId = product?.variants?.nodes?.[0]?.id || "";
            const price = product?.variants?.nodes?.[0]?.price?.amount || "0.00";
            const image = product?.images?.nodes?.[0]?.url || product?.featuredImage?.url || "https://placehold.co/400x400";
            return `
              <div class="bg-[#F6F6F6] rounded-xl p-6 flex flex-col items-center text-center relative group">
                <button class="btn-wishlist absolute top-4 right-4 transition-transform hover:scale-110" data-id="${product.id}" data-title="${product.title}" data-price="${price}" data-image="${image}" data-handle="${product.handle}" aria-label="Add to wishlist">
                  ${HEART_EMPTY}
                </button>
                <div class="w-full h-[200px] flex items-center justify-center mb-6 mt-4">
                  <img src="${image}" alt="${product.title}" class="max-h-full max-w-[80%] object-contain mix-blend-multiply transition-transform duration-300 group-hover:scale-105" />
                </div>
                <h3 class="text-sm font-medium text-black mb-2 line-clamp-2 px-2 h-[40px] leading-snug">${product.title}</h3>
                <p class="text-2xl font-bold text-black mb-6">$${price}</p>
                <button class="btn-add-to-cart w-full bg-black text-white font-medium py-3 rounded-lg hover:bg-gray-800 transition-colors mt-auto" data-variant-id="${variantId}">
                  Buy Now
                </button>
              </div>
            `;
          }).join('');
          bindEvents();
          syncHearts();
        } else {
          grid.innerHTML = '<p class="col-span-full text-center text-gray-500 py-10">No products found in this collection.</p>';
        }
      } catch (err) {
        console.error('Error fetching collection:', err);
      } finally {
        grid.classList.remove('opacity-50');
      }
    });
  });

  // Keep hearts in sync when wishlist changes (e.g. from wishlist page)
  window.addEventListener('wishlist:updated', syncHearts);

  // Initial sync
  bindEvents();
  syncHearts();
</script>
