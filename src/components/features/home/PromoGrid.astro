---
import { getProductsByCollection } from "../../../utils/shopify";

const bentoProducts = await getProductsByCollection("bento-grid", { first: 4 });

const getProductData = (product: any) => {
  if (!product) return null;
  return {
    title: product.title,
    description: product.description
      ? product.description.substring(0, 130) + "..."
      : "",
    image:
      product.images?.nodes?.[0]?.url ||
      product.featuredImage?.url ||
      "https://placehold.co/600x600",
    handle: product.handle,
  };
};

const p0 = getProductData(bentoProducts[0]);
const p1 = getProductData(bentoProducts[1]);
const p2 = getProductData(bentoProducts[2]);
const p3 = getProductData(bentoProducts[3]);
---

<section class="grid grid-cols-1 lg:grid-cols-2">
  <div class="flex flex-col">
    {
      p0 && (
        <a
          href={`/product/${p0.handle}`}
          class="group flex h-full flex-col items-center overflow-hidden bg-white transition-colors hover:bg-gray-50 md:flex-row lg:h-[350px]"
        >
          <div class="flex w-full justify-center p-8 md:w-1/2">
            <img
              src={p0.image}
              alt={p0.title}
              class="w-full max-w-[250px] object-cover mix-blend-multiply transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="w-full p-8 text-left md:w-1/2 md:pl-0">
            <h2 class="mb-4 text-4xl font-semibold text-black">{p0.title}</h2>
            <p class="max-w-sm text-sm leading-relaxed text-[#888]">
              {p0.description}
            </p>
          </div>
        </a>
      )
    }

    <div class="flex h-full flex-col md:flex-row lg:h-[350px]">
      {
        p1 && (
          <a
            href={`/product/${p1.handle}`}
            class="group relative flex w-full flex-col items-start justify-center overflow-hidden bg-[#EDEDED] p-8 md:w-1/2"
          >
            <div class="z-10 w-[60%]">
              <h2 class="mb-2 text-3xl leading-tight font-semibold text-black">
                {p1.title}
              </h2>
              <p class="mt-2 line-clamp-3 text-xs leading-relaxed text-[#888]">
                {p1.description}
              </p>
            </div>
            <img
              src={p1.image}
              alt={p1.title}
              class="absolute top-1/2 -right-12 w-[280px] -translate-y-1/2 object-contain mix-blend-multiply transition-transform duration-500 group-hover:scale-110"
            />
          </a>
        )
      }

      {
        p2 && (
          <a
            href={`/product/${p2.handle}`}
            class="group relative flex w-full flex-col items-end justify-center overflow-hidden bg-[#E0E0E0] p-8 text-right md:w-1/2"
          >
            <div class="z-10 w-[60%]">
              <h2 class="mb-2 text-3xl leading-tight font-semibold text-black">
                {p2.title}
              </h2>
              <p class="line-clamp-3 text-xs leading-relaxed text-[#666]">
                {p2.description}
              </p>
            </div>
            <img
              src={p2.image}
              alt={p2.title}
              class="absolute top-1/2 -left-12 w-[280px] -translate-y-1/2 object-contain mix-blend-multiply transition-transform duration-500 group-hover:scale-110"
            />
          </a>
        )
      }
    </div>
  </div>

  {
    p3 && (
      <div class="group relative flex min-h-[500px] flex-col items-center justify-between overflow-hidden bg-[#EDEDED] p-12 md:flex-row lg:h-[700px]">
        <div class="z-10 w-full text-left md:w-5/12">
          <h2 class="mb-4 text-5xl leading-tight font-semibold text-black">
            {p3.title}
          </h2>
          <p class="mb-8 max-w-sm text-sm leading-relaxed text-[#888]">
            {p3.description}
          </p>
          <a
            href={`/product/${p3.handle}`}
            class="inline-block rounded-md border border-black px-10 py-3 font-medium text-black transition-colors hover:bg-black hover:text-white"
          >
            Shop Now
          </a>
        </div>
        <div class="pointer-events-none absolute right-[-10%] bottom-[0%] flex h-[70%] w-[90%] justify-end md:h-[90%] md:w-[70%] lg:h-[100%]">
          <img
            src={p3.image}
            alt={p3.title}
            class="h-full w-auto object-cover object-left-bottom mix-blend-multiply drop-shadow-2xl transition-transform duration-700 ease-out group-hover:-translate-x-4"
          />
        </div>
      </div>
    )
  }
</section>
