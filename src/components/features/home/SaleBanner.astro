---
// src/components/features/home/SaleBanner.astro
// Esta sección muestra una "noticia": consume la colección con handle "noticias".
// - Título   = título de la colección
// - Texto    = descripción de la colección
// - Fondo    = imagen de la colección
// - Botón    = lleva a los productos de esa colección (/category/noticias)
import { getCollectionByHandle } from "../../../utils/collections";

const NEWS_HANDLE = "noticias";
const news = await getCollectionByHandle(NEWS_HANDLE);

// Fallbacks por si la colección "noticias" aún no existe en Shopify.
const title = news?.title || "Big Summer Sale";
const text =
  news?.description ||
  "Upgrade your arsenal. Tactical gear and field auditing tools at special prices for a limited time.";
const image = news?.image || null;
const link = news ? `/category/${NEWS_HANDLE}` : "/catalog";
---

<section
  class="relative mt-16 overflow-hidden bg-gradient-to-br from-[#2D2D2D] via-[#1A1A1A] to-[#000000] py-32"
>
  {
    image && (
      <img
        src={image}
        alt={title}
        class="absolute inset-0 z-0 h-full w-full object-cover"
      />
    )
  }

  <!-- Capa oscura para legibilidad del texto sobre la imagen -->
  <div class="absolute inset-0 z-0 bg-black/60"></div>

  <!-- Contenido -->
  <div class="relative z-10 container mx-auto max-w-7xl px-4 text-center">
    <h2 class="mb-4 text-5xl font-bold tracking-tight text-white drop-shadow-lg md:text-7xl">
      {title}
    </h2>
    <p class="mx-auto mb-10 max-w-xl text-sm text-gray-200 drop-shadow-md md:text-base line-clamp-4">
      {text}
    </p>
    <a
      href={link}
      class="inline-block rounded-md border border-white px-12 py-3 font-medium text-white transition-colors hover:bg-white hover:text-black"
    >
      Shop Now
    </a>
  </div>
</section>
