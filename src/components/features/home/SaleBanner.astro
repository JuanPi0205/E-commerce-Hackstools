---
// src/components/features/home/SaleBanner.astro
---

<section class="relative bg-gradient-to-br from-[#2D2D2D] via-[#1A1A1A] to-[#000000] overflow-hidden py-32 mt-16">
  
  <!-- Floating Images -->
  <img src="/images/promo_laptop.png" alt="" class="absolute top-[-20%] left-[-10%] w-[400px] object-contain opacity-80 mix-blend-screen transform -rotate-12 pointer-events-none" />
  <img src="/images/hero_hackrf.png" alt="" class="absolute bottom-[-15%] left-[5%] w-[300px] object-contain opacity-90 drop-shadow-2xl transform rotate-12 pointer-events-none" />
  
  <img src="/images/promo_flipper.png" alt="" class="absolute top-[-10%] right-[5%] w-[250px] object-contain opacity-90 drop-shadow-2xl transform rotate-12 pointer-events-none" />
  <img src="/images/promo_pineapple.png" alt="" class="absolute bottom-[-20%] right-[-5%] w-[400px] object-contain opacity-80 mix-blend-screen transform -rotate-12 pointer-events-none" />

  <!-- Content -->
  <div class="container mx-auto px-4 max-w-7xl relative z-10 text-center">
    <h2 class="text-5xl md:text-7xl font-light text-white mb-4 tracking-tight">Big Summer <span class="font-bold">Sale</span></h2>
    <p class="text-[#888] text-sm md:text-base mb-10 max-w-md mx-auto">Upgrade your arsenal. Tactical gear and field auditing tools at special prices for a limited time.</p>
    <a href="/shop" class="inline-block border border-white text-white px-12 py-3 rounded-md hover:bg-white hover:text-black transition-colors font-medium">Shop Now</a>
  </div>

</section>
