---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Shopping Cart | HackTools">
  <div class="min-h-screen flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-7xl">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">

        <div>
          <h1 class="text-3xl font-semibold text-black mb-10">Shopping Cart</h1>

          <div id="cart-empty" class="hidden py-20 text-center text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-4 opacity-40" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
            <p class="text-lg font-medium">Your cart is empty</p>
            <a href="/catalog" class="mt-4 inline-block text-sm underline text-black hover:opacity-70 transition-opacity">Continue Shopping</a>
          </div>

          <div id="cart-items" class="flex flex-col"></div>
        </div>

        <div class="flex items-start justify-center">
          <div class="sticky top-8 w-full">
            <h2 class="text-2xl font-semibold text-black mb-8">Order Summary</h2>

            <!-- Información de envío. El costo real lo calcula Shopify en el
                 checkout según la dirección del cliente. -->
            <div class="mb-8 rounded-xl border border-gray-100 bg-[#FAFAFA] p-4">
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                <div>
                  <p class="text-sm font-semibold text-black">Envío</p>
                  <p class="mt-1 text-sm text-[#888]">El costo de envío se calcula en el checkout según tu dirección de entrega.</p>
                </div>
              </div>
            </div>

            <div class="space-y-4 mb-8">
              <div class="flex justify-between items-center text-sm font-semibold">
                <span class="text-black">Subtotal</span>
                <span id="summary-subtotal" class="text-black">$0</span>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-[#888]">Estimated Tax</span>
                <span id="summary-tax" class="font-semibold text-black">$0</span>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-[#888]">Envío</span>
                <span class="font-medium text-[#888]">Calculado en el checkout</span>
              </div>
            </div>

            <div class="flex justify-between items-center mb-8">
              <span class="text-black font-semibold">Total</span>
              <span id="summary-total" class="text-black text-xl font-bold">$0</span>
            </div>

            <button id="btn-checkout" class="w-full bg-black text-white font-medium py-4 rounded-xl hover:bg-gray-800 transition-colors">
              Checkout
            </button>

          </div>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { cart, isCartUpdating, removeCartItem, updateCartItemQuantity } from '../stores/cart';

  function formatPrice(amount: string, currencyCode: string) {
    const num = parseFloat(amount);
    return new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: currencyCode,
    }).format(num);
  }

  function renderCart(cartData: any) {
    const cartItemsEl = document.getElementById('cart-items')!;
    const cartEmptyEl = document.getElementById('cart-empty')!;
    const subtotalEl = document.getElementById('summary-subtotal')!;
    const taxEl = document.getElementById('summary-tax')!;
    const totalEl = document.getElementById('summary-total')!;
    const checkoutBtn = document.getElementById('btn-checkout') as HTMLButtonElement;

    cartItemsEl.innerHTML = '';

    const nodes = cartData?.lines?.nodes || [];

    if (nodes.length === 0) {
      cartEmptyEl.classList.remove('hidden');
      cartItemsEl.classList.add('hidden');
      subtotalEl.textContent = formatPrice("0", "USD");
      taxEl.textContent = formatPrice("0", "USD");
      totalEl.textContent = formatPrice("0", "USD");
      if (checkoutBtn) {
        checkoutBtn.disabled = true;
        checkoutBtn.classList.add('opacity-50', 'cursor-not-allowed');
      }
      return;
    }

    cartEmptyEl.classList.add('hidden');
    cartItemsEl.classList.remove('hidden');

    const subtotal = cartData.cost.subtotalAmount;
    const totalTax = cartData.cost.totalTaxAmount;
    const total = cartData.cost.totalAmount;
    
    subtotalEl.textContent = formatPrice(subtotal?.amount || "0", subtotal?.currencyCode || "USD");
    taxEl.textContent = formatPrice(totalTax?.amount || "0", totalTax?.currencyCode || "USD");
    totalEl.textContent = formatPrice(total?.amount || "0", total?.currencyCode || "USD");

    // Lógica mejorada del Checkout
    if (checkoutBtn) {
      checkoutBtn.disabled = false;
      checkoutBtn.textContent = 'Checkout';
      checkoutBtn.classList.remove('opacity-50', 'cursor-not-allowed');

      checkoutBtn.onclick = () => {
        if (cartData.checkoutUrl) {
          checkoutBtn.textContent = 'Redirecting to secure checkout...';
          checkoutBtn.disabled = true;
          checkoutBtn.classList.add('opacity-50', 'cursor-not-allowed');
          window.location.href = cartData.checkoutUrl;
        }
      };
    }

    nodes.forEach((item: any) => {
      const merchandise = item.merchandise;
      const product = merchandise.product;
      const image = merchandise.image?.url || "https://placehold.co/400x400";
      const title = product.title;
      const priceAmount = item.cost.totalAmount.amount;
      const currencyCode = item.cost.totalAmount.currencyCode;

      // Stock disponible de la variante (null = inventario no rastreado → sin tope).
      const maxQty =
        typeof item.merchandise?.quantityAvailable === 'number'
          ? item.merchandise.quantityAvailable
          : null;
      const atMax = maxQty !== null && item.quantity >= maxQty;

      const row = document.createElement('div');
      row.className = 'flex items-center justify-between py-8 border-b border-gray-200 last:border-0';
      row.dataset.id = item.id;

      row.innerHTML = `
        <div class="flex items-center gap-6 w-[50%]">
          <div class="w-[100px] h-[100px] bg-[#F6F6F6] rounded-xl flex items-center justify-center p-2 shrink-0">
            <img src="${image}" alt="${title}" class="max-h-full max-w-full object-contain mix-blend-multiply" />
          </div>
          <div>
            <h3 class="font-medium text-black text-base">${title}</h3>
            ${merchandise.title && merchandise.title !== 'Default Title' ? `<p class="text-gray-500 text-sm mt-1">Variante: ${merchandise.title}</p>` : ''}
          </div>
        </div>

        <div class="flex flex-col items-center gap-1 w-[25%]">
          <div class="flex items-center gap-2">
            <button class="btn-decrease w-8 h-8 flex items-center justify-center text-black hover:bg-gray-100 rounded-md transition-colors border border-gray-200" ${item.quantity <= 1 ? 'disabled style="opacity: 0.5"' : ''}>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            </button>
            <span class="qty-display w-10 h-10 border border-gray-200 rounded-md flex items-center justify-center font-medium text-black text-sm">${item.quantity}</span>
            <button class="btn-increase w-8 h-8 flex items-center justify-center text-black hover:bg-gray-100 rounded-md transition-colors border border-gray-200 ${atMax ? 'opacity-40 cursor-not-allowed' : ''}" ${atMax ? 'disabled' : ''}>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            </button>
          </div>
          ${atMax ? `<span class="text-[11px] font-medium text-amber-600">Solo ${maxQty === 1 ? 'queda' : 'quedan'} ${maxQty}</span>` : ''}
        </div>

        <div class="flex items-center justify-end gap-8 w-[25%]">
          <p class="item-price text-lg font-medium text-black">${formatPrice(priceAmount, currencyCode)}</p>
          <button class="btn-remove text-gray-400 hover:text-red-500 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
      `;

      // Decrease quantity
      if (item.quantity > 1) {
        row.querySelector('.btn-decrease')!.addEventListener('click', () => {
          updateCartItemQuantity(item.id, item.quantity - 1);
        });
      }

      // Increase quantity (no superar el stock disponible)
      row.querySelector('.btn-increase')!.addEventListener('click', () => {
        if (maxQty !== null && item.quantity >= maxQty) return;
        updateCartItemQuantity(item.id, item.quantity + 1);
      });

      // Remove item entirely
      row.querySelector('.btn-remove')!.addEventListener('click', () => {
        // Animate out
        row.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
        row.style.opacity = '0';
        row.style.transform = 'translateX(16px)';
        setTimeout(() => {
          removeCartItem(item.id);
        }, 200);
      });

      cartItemsEl.appendChild(row);
    });
  }

  // Subscribe to Nanostores
  cart.subscribe((cartData) => {
    renderCart(cartData);
  });

  isCartUpdating.subscribe((updating) => {
    const checkoutBtn = document.getElementById('btn-checkout') as HTMLButtonElement;
    const qtyButtons = document.querySelectorAll('.btn-decrease, .btn-increase, .btn-remove');

    if (updating) {
      if (checkoutBtn) {
        checkoutBtn.disabled = true;
        checkoutBtn.textContent = 'Updating...';
        checkoutBtn.classList.add('opacity-50', 'cursor-not-allowed');
      }
      qtyButtons.forEach((btn: any) => btn.disabled = true);
    } else {
      if (checkoutBtn) {
        checkoutBtn.disabled = false;
        checkoutBtn.textContent = 'Checkout';
        checkoutBtn.classList.remove('opacity-50', 'cursor-not-allowed');
      }
      qtyButtons.forEach((btn: any) => btn.disabled = false);
    }
  });

</script>