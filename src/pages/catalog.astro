---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProducts } from '../utils/shopify';

// Traemos un lote amplio para que los filtros cubran el catálogo.
const products = await getProducts({ first: 100 });

// Colecciones internas que NO deben aparecer como filtro de categoría.
const EXCLUDED_HANDLES = ['bento-grid', 'frontpage', 'noticias'];

// Construimos los grupos de filtros DINÁMICAMENTE desde los productos reales:
// - Categorías: colecciones a las que pertenece cada producto.
// - Etiquetas: tags de cada producto.
const categoryMap = new Map<string, { label: string; count: number }>();
const tagMap = new Map<string, number>();

for (const p of products as any[]) {
  const cols = p?.collections?.nodes ?? [];
  for (const c of cols) {
    if (!c?.handle || EXCLUDED_HANDLES.includes(c.handle)) continue;
    const existing = categoryMap.get(c.handle);
    if (existing) existing.count++;
    else categoryMap.set(c.handle, { label: c.title || c.handle, count: 1 });
  }
  const tags = p?.tags ?? [];
  for (const t of tags) {
    if (!t) continue;
    tagMap.set(t, (tagMap.get(t) ?? 0) + 1);
  }
}

const categoryFilters = Array.from(categoryMap.entries())
  .map(([handle, v]) => ({ value: handle, label: v.label, count: v.count }))
  .sort((a, b) => a.label.localeCompare(b.label));

const tagFilters = Array.from(tagMap.entries())
  .map(([tag, count]) => ({ value: tag, label: tag, count }))
  .sort((a, b) => a.label.localeCompare(b.label));

const hasFilters = categoryFilters.length > 0 || tagFilters.length > 0;
---

<BaseLayout title="Catalog | HackTools">
  <div class="w-full max-w-7xl mx-auto px-6 py-12">
    <div class="flex flex-col lg:flex-row gap-10">

      <!-- ───────── Barra lateral de filtros ───────── -->
      {hasFilters && (
        <aside class="w-full lg:w-64 shrink-0">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-semibold text-black">Filtros</h2>
            <button id="clear-filters" class="text-xs font-medium text-gray-400 underline underline-offset-2 hover:text-black transition-colors" style="display:none">
              Limpiar
            </button>
          </div>

          {categoryFilters.length > 0 && (
            <div class="mb-8">
              <h3 class="text-sm font-semibold text-black mb-3">Categorías</h3>
              <ul class="space-y-2">
                {categoryFilters.map((f) => (
                  <li>
                    <label class="flex items-center gap-2 text-sm text-[#555] cursor-pointer hover:text-black">
                      <input type="checkbox" class="filter-checkbox accent-black" data-filter-group="category" value={f.value} />
                      <span class="flex-1">{f.label}</span>
                      <span class="text-xs text-gray-400">{f.count}</span>
                    </label>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {tagFilters.length > 0 && (
            <div class="mb-8">
              <h3 class="text-sm font-semibold text-black mb-3">Etiquetas</h3>
              <ul class="space-y-2">
                {tagFilters.map((f) => (
                  <li>
                    <label class="flex items-center gap-2 text-sm text-[#555] cursor-pointer hover:text-black">
                      <input type="checkbox" class="filter-checkbox accent-black" data-filter-group="tag" value={f.value} />
                      <span class="flex-1">{f.label}</span>
                      <span class="text-xs text-gray-400">{f.count}</span>
                    </label>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      )}

      <!-- ───────── Columna principal ───────── -->
      <div class="flex-1 min-w-0">

        <!-- Top Bar -->
        <div class="flex justify-between items-center mb-8">
          <p class="text-[#888] text-sm font-medium">
            Selected Products: <span id="product-count" class="text-black font-semibold text-lg ml-1">{products.length}</span>
          </p>
          <div class="relative">
            <select id="sort-select" class="appearance-none border border-gray-200 rounded-lg px-4 py-2 pr-10 text-sm focus:outline-none focus:border-black bg-white w-[180px] cursor-pointer">
              <option value="default">By rating</option>
              <option value="price-asc">Price: Low to High</option>
              <option value="price-desc">Price: High to Low</option>
              <option value="newest">Newest Arrivals</option>
            </select>
          </div>
        </div>

        <!-- Product Grid -->
        <div id="product-grid" class="grid grid-cols-2 lg:grid-cols-3 gap-4">
          {products.map((product, index) => {
            const variantId = product?.variants?.nodes?.[0]?.id || "";
            const price = product?.variants?.nodes?.[0]?.price?.amount || "0.00";
            const image = product?.images?.nodes?.[0]?.url || product?.featuredImage?.url || "https://placehold.co/400x400";
            const productCategories = ((product as any)?.collections?.nodes ?? []).map((c: any) => c.handle).filter(Boolean);
            const productTags = (product as any)?.tags ?? [];

            return (
            <div
              class="bg-[#F6F6F6] rounded-2xl p-5 flex flex-col items-center text-center relative group"
              data-index={index}
              data-price={price}
              data-created={product?.createdAt || ""}
              data-categories={productCategories.join("|")}
              data-tags={productTags.join("|")}
            >

              <!-- Wishlist Button -->
              <button
                class="btn-wishlist absolute top-4 right-4 z-10 transition-transform hover:scale-110"
                data-id={product?.id}
                data-title={product?.title}
                data-price={price}
                data-image={image}
                data-handle={product?.handle}
                aria-label="Add to wishlist"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#CFCFCF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
              </button>

              <!-- Product Image & Title Link -->
              <a href={`/product/${product?.handle}`} class="w-full flex flex-col items-center">
                <div class="w-full h-[160px] flex items-center justify-center mb-4 mt-2">
                  <img src={image} alt={product?.title} class="max-h-full max-w-[75%] object-contain mix-blend-multiply transition-transform duration-300 group-hover:scale-105" />
                </div>
                <h3 class="text-[13px] font-medium text-black mb-2 line-clamp-2 leading-snug min-h-[36px] px-1 hover:underline">{product?.title}</h3>
              </a>
              <p class="text-lg font-bold text-black mb-4">${price}</p>

              <button
                class="btn-add-to-cart w-full bg-black text-white font-medium py-2.5 rounded-lg hover:bg-gray-800 transition-colors mt-auto text-sm"
                data-variant-id={variantId}
              >
                Buy Now
              </button>
            </div>
          )})}
        </div>

        <!-- Mensaje cuando no hay resultados tras filtrar -->
        <div id="no-results" class="hidden rounded-2xl border border-gray-100 bg-[#FAFAFA] p-16 text-center">
          <p class="text-gray-500">No hay productos que coincidan con los filtros seleccionados.</p>
        </div>

        <!-- Paginación (la genera el script según los resultados) -->
        <div id="pagination" class="flex justify-center items-center gap-2 mt-12"></div>

      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { addCartItem } from '../stores/cart';
  import { toggleWishlist, isInWishlist } from '../utils/wishlist';

  const HEART_EMPTY = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#CFCFCF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>`;
  const HEART_FILLED = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#EF4444" stroke="#EF4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>`;

  function syncHearts() {
    document.querySelectorAll<HTMLButtonElement>('.btn-wishlist').forEach((btn) => {
      btn.innerHTML = isInWishlist(btn.dataset.id!) ? HEART_FILLED : HEART_EMPTY;
    });
  }

  document.querySelectorAll<HTMLButtonElement>('.btn-wishlist').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try {
        await toggleWishlist({
          id: btn.dataset.id!,
          title: btn.dataset.title!,
          price: parseFloat(btn.dataset.price!),
          image: btn.dataset.image!,
          handle: btn.dataset.handle!,
        });
        syncHearts();
      } catch (err: any) {
        alert('Error: ' + err.message);
        console.error(err);
      }
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.btn-add-to-cart').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const variantId = btn.dataset.variantId!;
      if (!variantId) return;

      const orig = btn.textContent;
      btn.textContent = 'Adding...';
      btn.disabled = true;

      await addCartItem({ variantId, quantity: 1 });

      btn.textContent = '✓ Added!';
      btn.classList.replace('bg-black', 'bg-green-600');
      btn.classList.remove('hover:bg-gray-800');
      setTimeout(() => {
        btn.textContent = orig;
        btn.disabled = false;
        btn.classList.replace('bg-green-600', 'bg-black');
        btn.classList.add('hover:bg-gray-800');
      }, 1200);
    });
  });

  window.addEventListener('wishlist:updated', syncHearts);
  syncHearts();

  // ── Filtros + Orden + Paginación ─────────────────────────────────────────────
  const ITEMS_PER_PAGE = 9;
  let currentPage = 1;

  const grid = document.getElementById('product-grid');
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement | null;
  const paginationEl = document.getElementById('pagination');
  const countEl = document.getElementById('product-count');
  const noResultsEl = document.getElementById('no-results');
  const clearBtn = document.getElementById('clear-filters');

  const selectedCategories = new Set<string>();
  const selectedTags = new Set<string>();

  const allCards = Array.from(grid?.querySelectorAll<HTMLElement>('[data-index]') ?? []);

  function matchesFilters(card: HTMLElement) {
    const cats = (card.dataset.categories || '').split('|').filter(Boolean);
    const tags = (card.dataset.tags || '').split('|').filter(Boolean);
    const catOk = selectedCategories.size === 0 || cats.some((c) => selectedCategories.has(c));
    const tagOk = selectedTags.size === 0 || tags.some((t) => selectedTags.has(t));
    return catOk && tagOk;
  }

  function sortCards(cards: HTMLElement[], criteria: string) {
    return [...cards].sort((a, b) => {
      const pa = parseFloat(a.dataset.price ?? '0');
      const pb = parseFloat(b.dataset.price ?? '0');
      const ca = a.dataset.created ?? '';
      const cb = b.dataset.created ?? '';
      switch (criteria) {
        case 'price-asc': return pa - pb;
        case 'price-desc': return pb - pa;
        case 'newest': return cb.localeCompare(ca);
        default:
          return parseInt(a.dataset.index ?? '0', 10) - parseInt(b.dataset.index ?? '0', 10);
      }
    });
  }

  function renderPagination(totalPages: number) {
    if (!paginationEl) return;
    paginationEl.innerHTML = '';
    if (totalPages <= 1) return;

    const mkBtn = (label: string, onClick: () => void, opts: { disabled?: boolean; active?: boolean } = {}) => {
      const b = document.createElement('button');
      b.innerHTML = label;
      b.className = 'w-8 h-8 flex items-center justify-center font-medium rounded-md text-sm transition-colors';
      if (opts.active) b.classList.add('bg-black', 'text-white');
      else b.classList.add('text-black', 'hover:bg-gray-100');
      if (opts.disabled) b.style.opacity = '0.3';
      b.addEventListener('click', onClick);
      return b;
    };

    paginationEl.appendChild(
      mkBtn(
        '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>',
        () => { if (currentPage > 1) { currentPage--; render(); scrollToGrid(); } },
        { disabled: currentPage === 1 }
      )
    );

    for (let p = 1; p <= totalPages; p++) {
      paginationEl.appendChild(
        mkBtn(String(p), () => { currentPage = p; render(); scrollToGrid(); }, { active: p === currentPage })
      );
    }

    paginationEl.appendChild(
      mkBtn(
        '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>',
        () => { if (currentPage < totalPages) { currentPage++; render(); scrollToGrid(); } },
        { disabled: currentPage === totalPages }
      )
    );
  }

  function scrollToGrid() {
    grid?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function render() {
    if (!grid) return;

    const filtered = allCards.filter(matchesFilters);
    const sorted = sortCards(filtered, sortSelect?.value ?? 'default');

    // Ocultamos todo y reordenamos los visibles según el orden aplicado.
    allCards.forEach((c) => { c.style.display = 'none'; });
    sorted.forEach((c) => grid.appendChild(c));

    const totalPages = Math.max(1, Math.ceil(sorted.length / ITEMS_PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;

    const start = (currentPage - 1) * ITEMS_PER_PAGE;
    sorted.slice(start, start + ITEMS_PER_PAGE).forEach((c) => { c.style.display = ''; });

    if (countEl) countEl.textContent = String(filtered.length);
    if (noResultsEl) noResultsEl.classList.toggle('hidden', filtered.length > 0);

    renderPagination(totalPages);

    // Mantener corazones sincronizados tras reordenar
    syncHearts();
  }

  // Checkboxes de filtros
  document.querySelectorAll<HTMLInputElement>('.filter-checkbox').forEach((cb) => {
    cb.addEventListener('change', () => {
      const group = cb.dataset.filterGroup;
      const set = group === 'category' ? selectedCategories : selectedTags;
      if (cb.checked) set.add(cb.value);
      else set.delete(cb.value);

      if (clearBtn) {
        clearBtn.style.display =
          selectedCategories.size + selectedTags.size > 0 ? '' : 'none';
      }

      currentPage = 1;
      render();
    });
  });

  clearBtn?.addEventListener('click', () => {
    selectedCategories.clear();
    selectedTags.clear();
    document.querySelectorAll<HTMLInputElement>('.filter-checkbox').forEach((cb) => { cb.checked = false; });
    clearBtn.style.display = 'none';
    currentPage = 1;
    render();
  });

  sortSelect?.addEventListener('change', () => { currentPage = 1; render(); });

  // Estado inicial
  render();
</script>
