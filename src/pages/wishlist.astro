---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Wishlist | HackTools">
  <div class="min-h-screen px-4 py-16">
    <div class="w-full max-w-7xl mx-auto">

      <div class="flex items-center justify-between mb-10">
        <h1 class="text-3xl font-semibold text-black">My Wishlist</h1>
        <span id="wishlist-count" class="text-sm text-[#888]"></span>
      </div>

      <!-- Empty state -->
      <div id="wishlist-empty" class="hidden py-28 text-center text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-4 opacity-30" width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
        <p class="text-lg font-medium">Your wishlist is empty</p>
        <a href="/catalog" class="mt-4 inline-block text-sm underline text-black hover:opacity-70 transition-opacity">Browse Products</a>
      </div>

      <!-- Wishlist grid -->
      <div id="wishlist-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6"></div>

    </div>
  </div>
</BaseLayout>

<script>
  import { getWishlist, removeFromWishlist } from '../utils/wishlist';
  import { addToCart } from '../utils/cart';

  function renderWishlist() {
    const items = getWishlist();
    const grid = document.getElementById('wishlist-grid')!;
    const empty = document.getElementById('wishlist-empty')!;
    const countEl = document.getElementById('wishlist-count')!;

    grid.innerHTML = '';

    if (items.length === 0) {
      empty.classList.remove('hidden');
      grid.classList.add('hidden');
      countEl.textContent = '';
      return;
    }

    empty.classList.add('hidden');
    grid.classList.remove('hidden');
    countEl.textContent = `${items.length} item${items.length === 1 ? '' : 's'}`;

    items.forEach((item) => {
      const card = document.createElement('div');
      card.className = 'bg-[#F6F6F6] rounded-2xl p-5 flex flex-col items-center text-center relative group';
      card.dataset.id = item.id;

      card.innerHTML = `
        <!-- Remove button -->
        <button class="btn-remove-wish absolute top-3 right-3 w-7 h-7 flex items-center justify-center text-gray-300 hover:text-red-500 transition-colors rounded-full hover:bg-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>

        <!-- Heart filled -->
        <div class="absolute top-3 left-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#EF4444" stroke="#EF4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
        </div>

        <!-- Image -->
        <div class="w-full h-[160px] flex items-center justify-center mb-4 mt-6">
          <img src="${item.image}" alt="${item.title}" class="max-h-full max-w-[75%] object-contain mix-blend-multiply transition-transform duration-300 group-hover:scale-105" />
        </div>

        <!-- Details -->
        <h3 class="text-[13px] font-medium text-black mb-2 line-clamp-2 leading-snug min-h-[36px] px-1">${item.title}</h3>
        <p class="text-lg font-bold text-black mb-4">$${item.price}</p>

        <button class="btn-add-cart w-full bg-black text-white font-medium py-2.5 rounded-lg hover:bg-gray-800 transition-colors mt-auto text-sm">
          Add to Cart
        </button>
      `;

      // Remove from wishlist
      card.querySelector('.btn-remove-wish')!.addEventListener('click', () => {
        card.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
        card.style.opacity = '0';
        card.style.transform = 'scale(0.95)';
        setTimeout(() => {
          removeFromWishlist(item.id);
          renderWishlist();
        }, 200);
      });

      // Add to cart
      const addBtn = card.querySelector('.btn-add-cart') as HTMLButtonElement;
      addBtn.addEventListener('click', () => {
        addToCart({ id: item.id, title: item.title, handle: item.handle, price: item.price, image: item.image });
        const orig = addBtn.textContent;
        addBtn.textContent = '✓ Added!';
        addBtn.classList.replace('bg-black', 'bg-green-600');
        addBtn.classList.remove('hover:bg-gray-800');
        setTimeout(() => {
          addBtn.textContent = orig;
          addBtn.classList.replace('bg-green-600', 'bg-black');
          addBtn.classList.add('hover:bg-gray-800');
        }, 1200);
      });

      grid.appendChild(card);
    });
  }

  renderWishlist();
  window.addEventListener('wishlist:updated', renderWishlist);
</script>
